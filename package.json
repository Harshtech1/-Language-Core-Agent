{
  "name": "hsk-agent-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "730-Day Autonomous Chinese Language Tutor — HSK 1-4 Mastery Agent",
  "scripts": {
    "dev:web": "cd web && npm run dev",
    "build:web": "cd web && npm run build",
    "dev:api": "py -3.12 -m uvicorn api.main:app --reload --port 8000",
    "seed": "cd api && py -3.12 -m workers.seed_hsk",
    "test:srs": "cd api && py -3.12 -m pytest tests/ -v"
  },
  "workspaces": [
    "web"
  ]
}
