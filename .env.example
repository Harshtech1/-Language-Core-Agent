# ── OpenRouter ──────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxx

# ── MongoDB Atlas ──────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/hsk_agent?retryWrites=true&w=majority

# ── Telegram Bot ───────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
# Primary (owner) ID first; add guest IDs after a comma for the Puneet Test, etc.
TELEGRAM_ALLOWED_CHAT_IDS=123456789

# ── API Security ───────────────────────────────────────
CRON_SECRET=your-random-secret-for-cron-auth

# ── Model Selection ───────────────────────────────────
# Morning lesson generation (premium quality)
MODEL_LESSON=anthropic/claude-3.5-sonnet
# Evening evaluation (budget, high-throughput)
MODEL_EVAL=google/gemini-3.1-flash-lite
